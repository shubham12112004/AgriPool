# Laravel API
VITE_API_URL=http://127.0.0.1:8000/api

# Laravel web URL (Google OAuth — must match running backend)
VITE_APP_URL=http://127.0.0.1:8000

# Reverb websocket settings
VITE_REVERB_APP_KEY=local
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=ws

# Cloudflare Turnstile (optional — test keys work locally)
# Get keys: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
